# Google OAuth credentials.
#
# Recommended: create a "Web application" OAuth client in Google Cloud, add this
# exact URI to Authorized redirect URIs, and set GOOGLE_CLIENT_ID,
# GOOGLE_CLIENT_SECRET, and GOOGLE_REDIRECT_URI below.
#
# Local-only alternative: create a "Desktop app" OAuth client, download its JSON,
# store it outside the repo, and set GOOGLE_OAUTH_KEYS_PATH to that file. When the
# JSON contains redirect_uris, GOOGLE_REDIRECT_URI can be omitted from your .env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/callback
# GOOGLE_OAUTH_KEYS_PATH=/home/you/.config/google-tasks-mcp/gcp-oauth.keys.json

# Required when running the HTTP transport and connecting to /mcp.
# Not required when an MCP client runs the server with --transport stdio.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_BEARER_TOKEN=

# Runtime settings. DB_PATH must point to a persistent SQLite database file.
DB_PATH=./google-tasks.db
BIND_HOST=127.0.0.1
BIND_PORT=8787
LOG_LEVEL=INFO

# Optional Google tasklist title or ID to use when a tool omits tasklist.
DEFAULT_TASKLIST=

# OAuth 2.0 gateway — required when serving over HTTP to OAuth clients (e.g. any MCP web client).
# Not needed when an MCP client connects via MCP_BEARER_TOKEN only.
#
# MCP_OAUTH_ISSUER      — public HTTPS base URL of this server (no trailing slash)
# MCP_OAUTH_CLIENT_ID   — arbitrary identifier for the connecting MCP client
# MCP_OAUTH_CLIENT_SECRET — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MCP_OAUTH_SIGNING_SECRET — generate: python -c "import secrets; print(secrets.token_hex(32))"
# MCP_OAUTH_REDIRECT_URIS — comma-separated allowlist of redirect URIs for your MCP client(s);
#                            check your client's documentation for the correct callback URL.
#                            Leave unset for Bearer-only mode (OAuth disabled, no error).
# MCP_OAUTH_ADMIN_PASSWORD — optional; if set, the consent screen requires this password
MCP_OAUTH_ISSUER=
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
MCP_OAUTH_SIGNING_SECRET=
MCP_OAUTH_REDIRECT_URIS=
# MCP_OAUTH_ADMIN_PASSWORD=
