# Google OAuth credentials.
# Set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET, or place the downloaded OAuth
# client JSON at GOOGLE_OAUTH_KEYS_PATH.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/callback
GOOGLE_OAUTH_KEYS_PATH=gcp-oauth.keys.json

# Required when running the HTTP transport and connecting to /mcp.
# Not required when an MCP client runs the server with --transport stdio.
MCP_BEARER_TOKEN=

# Runtime settings. DB_PATH must point to a persistent SQLite database file.
DB_PATH=./google-tasks.db
BIND_HOST=127.0.0.1
BIND_PORT=8787
LOG_LEVEL=INFO

# Optional Google tasklist title or ID to use when a tool omits tasklist.
DEFAULT_TASKLIST=
